PValue <- 0.01
Alpha <- 0.05 #0.05 if not specified
# If p-value is SMALL (less than 0.05) → REJECT H₀
# If p-value is BIG (0.05 or more) → FAIL TO REJECT H₀
if (PValue < Alpha) {
print("REJECT H₀")
} else {
print("FAIL TO REJECT H₀ / Not Enough Evidence")
}
# You dont accept. You just fail to Reject / Not enough evidence
