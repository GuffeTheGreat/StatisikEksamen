# Sample size
n <- length(energy)
# Sample variance (unbiased, denominator n-1)
s2 <- var(energy)
# Degrees of freedom
df <- n - 1
# Chi-squared critical values
chi2_lower <- qchisq(0.025, df)   # α/2 = 0.025
chi2_upper <- qchisq(0.975, df)   # 1-α/2 = 0.975
# Confidence interval for variance
ci_variance_lower <- (df * s2) / chi2_upper
ci_variance_upper <- (df * s2) / chi2_lower
# Confidence interval for standard deviation (take square root)
ci_sd_lower <- sqrt(ci_variance_lower)
ci_sd_upper <- sqrt(ci_variance_upper)
# Results
ci_sd_lower
ci_sd_upper
